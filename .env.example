# -------------------------------------------------------------------
# Environment Variables Example File
# -------------------------------------------------------------------
# Instructions:
# 1. Copy this file and rename it to `.env`
# 2. Fill in the values specific to your local machine and accounts
# 3. DO NOT commit your actual `.env` file to GitHub!
# -------------------------------------------------------------------

# 1. Supabase Database Connection
# You can find this in your Supabase Dashboard -> Database -> Connection String
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# 2. Google Shared Drive Linked Data Folder
# This must point to the specific path on your computer where the Google Drive maps to.
# Example for Windows: G:/Shared drives/DigiTwin/railway-flood-twin/data
# Example for Mac: /Volumes/GoogleDrive/Shared drives/DigiTwin/railway-flood-twin/data
DATA_ROOT=G:/Shared drives/DigiTwin/railway-flood-twin/data
